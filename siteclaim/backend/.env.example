# SiteSource backend configuration — copy to backend/.env and fill in.
# backend/.env is gitignored; NEVER commit a real key. DEMO_MODE needs no key.

# Extraction / composition provider for the Layer 2 (Claude) stages.
EXTRACTION_PROVIDER=anthropic

# Required when EXTRACTION_PROVIDER=anthropic (live ingest / compose only).
ANTHROPIC_API_KEY=

# Optional OpenAI-compatible alternative (text-only).
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro

# Offline demo: when true, the whole pipeline reads fixtures and the seeded DB and
# makes zero network calls and loads no model.
DEMO_MODE=true
