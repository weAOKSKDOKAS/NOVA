# SiteClaim backend configuration — copy to backend/.env and fill in.
# backend/.env is gitignored; NEVER commit a real key.

# Extraction provider: "anthropic" (default — reads PDF/images natively) or
# "deepseek" (OpenAI-compatible, text-only — DeepSeek V4 rejects image input).
EXTRACTION_PROVIDER=anthropic

# Required when EXTRACTION_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Required when EXTRACTION_PROVIDER=deepseek; optional model override.
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro

# Offline demo: when true, the pipeline reads fixtures and makes zero network calls.
DEMO_MODE=true
